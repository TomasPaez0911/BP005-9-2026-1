#include <stdio.h>
#include <stdbool.h>

int main() {

    // Mensaje de bienvenida
    printf("=== SISTEMA DE ANALISIS ACADEMICO ===\n\n");

    // Variables
    int codigo, edad;
    float nota1, nota2, nota3, promedio;
    double matricula;
    char inicialApellido;
    char nombre[50];

    bool matriculaActiva, documento, induccion, monitor;
    bool accesoLab;

    int temp; // para leer valores booleanos correctamente

    // Entrada de datos
    printf("Ingrese codigo del estudiante: ");
    scanf("%d", &codigo);

    printf("Ingrese nombre completo: ");
    scanf(" %[^\n]", nombre); // permite espacios

    printf("Ingrese inicial del apellido: ");
    scanf(" %c", &inicialApellido);

    printf("Ingrese edad: ");
    scanf("%d", &edad);

    printf("Ingrese nota 1: ");
    scanf("%f", &nota1);

    printf("Ingrese nota 2: ");
    scanf("%f", &nota2);

    printf("Ingrese nota 3: ");
    scanf("%f", &nota3);

    printf("Ingrese valor de matricula: ");
    scanf("%lf", &matricula);

    // Lectura de booleanos correctamente
    printf("Tiene matricula activa? (1=si, 0=no): ");
    scanf("%d", &temp);
    matriculaActiva = temp;

    printf("Presento documento? (1=si, 0=no): ");
    scanf("%d", &temp);
    documento = temp;

    printf("Aprobo induccion? (1=si, 0=no): ");
    scanf("%d", &temp);
    induccion = temp;

    printf("Es monitor? (1=si, 0=no): ");
    scanf("%d", &temp);
    monitor = temp;

if (codigo % 2 == 0) {

    printf("El codigo es: PAR\n");

} else {

    printf("El codigo es: IMPAR\n");

}    // Validación de notas
    if (nota1 < 0 || nota1 > 5 || nota2 < 0 || nota2 > 5 || nota3 < 0 || nota3 > 5) {
        printf("\nError: Las notas deben estar entre 0 y 5.\n");
        return 0;
    }

    // Promedio
    promedio = (nota1 + nota2 + nota3) / 3;

    // Par o impar
    if (codigo % 2 == 0) {
    printf("El codigo es: PAR\n");
} else {
    printf("El codigo es: IMPAR\n");
}
    // Clasificación
    if (promedio < 3.0) {
        printf("Desempeno: Reprobado\n");
    } else if (promedio < 4.0) {
        printf("Desempeno: Aceptable\n");
    } else if (promedio < 4.5) {
        printf("Desempeno: Bueno\n");
    } else {
        printf("Desempeno: Excelente\n");
    }

    // Acceso al laboratorio
    accesoLab = matriculaActiva && documento && (induccion || monitor);

    if (accesoLab) {
        printf("\nAcceso al laboratorio: PERMITIDO\n");

        if (monitor) {
            printf("Rol: Monitor\n");
        } else {
            printf("Rol: Estudiante\n");
        }

    } else {
        printf("\nAcceso al laboratorio: DENEGADO\n");
    }

    // Resumen final
    printf("\n=== RESUMEN FINAL ===\n");
    printf("Codigo: %d \n", codigo );
    printf("Nombre: %s %c\n", nombre, inicialApellido);
    printf("Edad: %d\n", edad);
    printf("Promedio: %.2f\n", promedio);
    printf("Matricula: %.2lf\n", matricula);

    return 0;
}
