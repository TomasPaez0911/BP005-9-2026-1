#include <stdio.h>

 int main() {
    int contador = 1; //controlar cuantas veces repetimos
    int numero; // almacena cada numero ingresado
    int suma = 0; //acumulador 

    while (contador <= 3) { //se repetira 3 veces
         printf("ingrese un numero: ");
         scanf("%d" , &numero);

      suma = suma + numero; //acumula el valor leido
      contador++; //avanza el siguente ciclo
  }

   printf("la suma es: %d\n" , suma);
  
   return 0;
}

